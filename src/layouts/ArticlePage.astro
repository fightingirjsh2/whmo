---
import Base from "./Base.astro";
import TagList from "../components/TagList.astro";
import RelatedPosts from "../components/RelatedPosts.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  image?: string;
  tags: string[];
  currentId: string;
  collection: "gaming" | "current-events" | "sports";
  backHref: string;
  backLabel: string;
  accentVar: string;
  feedLabel: string;
}

const { title, description, date, author, image, tags, currentId, collection, backHref, backLabel, accentVar, feedLabel } = Astro.props;
const dateStr = date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
---

<Base title={title} description={description} ogImage={image} ogType="article">
  {image && (
    <div class="article-hero">
      <img src={image} alt="" class="article-hero__img" />
    </div>
  )}
  <div class="container">
    <article class="article">
      <a class="back-link" href={backHref}>&#8592; {backLabel}</a>
      <p class="kicker article__kicker" style={`color: var(${accentVar})`}>{feedLabel}</p>
      <h1 class="article__title">{title}</h1>
      <p class="article__meta">{author} &middot; {dateStr}</p>
      <div class="article__body" style={`--link-color: var(${accentVar})`}>
        <slot />
      </div>
      {tags.length > 0 && (
        <footer class="article__footer">
          <TagList tags={tags} />
        </footer>
      )}
    </article>
    <RelatedPosts
      currentId={currentId}
      tags={tags}
      collection={collection}
      accentVar={accentVar}
      feedLabel={feedLabel}
      backHref={backHref}
    />
  </div>
</Base>
