---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const [gaming, events, sports] = await Promise.all([
  getCollection("gaming"),
  getCollection("current-events"),
  getCollection("sports"),
]);

const latest = (posts: typeof gaming) =>
  posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())[0];

const feeds = [
  {
    id: "gaming",
    label: "Gaming\n& Hobbies",
    href: "/gaming",
    accentVar: "--gaming",
    latest: latest(gaming),
    count: gaming.length,
    tagline: "Reviews, previews, and takes on games and the hobby space.",
  },
  {
    id: "current-events",
    label: "Current\nEvents",
    href: "/current-events",
    accentVar: "--events",
    latest: latest(events),
    count: events.length,
    tagline: "News, policy, and the stories worth slowing down for.",
  },
  {
    id: "sports",
    label: "Sports",
    href: "/sports",
    accentVar: "--sports",
    latest: latest(sports),
    count: sports.length,
    tagline: "Games, numbers, and what they actually mean.",
  },
];
---

<Base title="Wait, Hear Me Out...">
  <div class="splash">
    {feeds.map((feed) => {
      const slug = feed.latest?.id.replace(/\.md$/, "");
      return (
        <a class="splash__section" href={feed.href} data-feed={feed.id} style={`--accent: var(${feed.accentVar})`}>
          <div class="splash__inner">
            <p class="splash__count kicker">{feed.count} {feed.count === 1 ? "article" : "articles"}</p>
            <h2 class="splash__title">{feed.label}</h2>
            <p class="splash__tagline">{feed.tagline}</p>
            {feed.latest && (
              <p class="splash__latest">
                <span class="splash__latest-label">Latest</span>
                {feed.latest.data.title}
              </p>
            )}
            <span class="splash__cta">Read all &#8594;</span>
          </div>
        </a>
      );
    })}
  </div>
</Base>
