---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const [destiny, gaming, tvMovies, worldPolitics, sports] = await Promise.all([
  getCollection("destiny", ({ data }) => !data.draft),
  getCollection("gaming", ({ data }) => !data.draft),
  getCollection("tv-movies", ({ data }) => !data.draft),
  getCollection("world-politics", ({ data }) => !data.draft),
  getCollection("sports", ({ data }) => !data.draft),
]);

const recents = (posts: typeof gaming, n = 3) =>
  [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, n);

const slug = (id: string) => id.replace(/^.*\//, "").replace(/\.md$/, "");

const feeds = [
  {
    id: "destiny",
    label: "Destiny",
    shortLabel: "Destiny",
    href: "/destiny",
    accentVar: "--destiny",
    recents: recents(destiny),
    count: destiny.length,
    tagline: "Bungie, Destiny, and the universe they built.",
  },
  {
    id: "gaming",
    label: "Gaming &\nThe Industry",
    shortLabel: "Gaming",
    href: "/gaming",
    accentVar: "--gaming",
    recents: recents(gaming),
    count: gaming.length,
    tagline: "Reviews, previews, and takes on games and the hobby space.",
  },
  {
    id: "tv-movies",
    label: "TV &\nMovies",
    shortLabel: "TV & Movies",
    href: "/tv-movies",
    accentVar: "--tv-movies",
    recents: recents(tvMovies),
    count: tvMovies.length,
    tagline: "The shows and films worth your time.",
  },
  {
    id: "world-politics",
    label: "World &\nPolitics",
    shortLabel: "World & Politics",
    href: "/world-politics",
    accentVar: "--world-politics",
    recents: recents(worldPolitics),
    count: worldPolitics.length,
    tagline: "News, policy, and the stories worth slowing down for.",
  },
  {
    id: "sports",
    label: "Sports",
    shortLabel: "Sports",
    href: "/sports",
    accentVar: "--sports",
    recents: recents(sports),
    count: sports.length,
    tagline: "Games, numbers, and what they actually mean.",
  },
];
---

<Base title="Wait, Hear Me Out...">
  <div class="splash">
    {feeds.map((feed) => (
      <div class="splash__section" data-feed={feed.id} style={`--accent: var(${feed.accentVar})`}>
        <span class="splash__vert-title" aria-hidden="true">{feed.shortLabel}</span>
        <div class="splash__inner">
          <p class="splash__count kicker">{feed.count} {feed.count === 1 ? "article" : "articles"}</p>
          <h2 class="splash__title">
            <a class="splash__title-link" href={feed.href}>{feed.label}</a>
          </h2>
          <p class="splash__tagline">{feed.tagline}</p>
          {feed.recents.length > 0 && (
            <ul class="splash__articles">
              {feed.recents.map((article) => (
                <li>
                  <a class="splash__article-link" href={`${feed.href}/${slug(article.id)}`}>
                    {article.data.title}
                  </a>
                </li>
              ))}
            </ul>
          )}
          <a class="splash__cta" href={feed.href}>Read all &#8594;</a>
        </div>
      </div>
    ))}
  </div>
</Base>
